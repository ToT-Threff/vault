rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────────────────

    // Ryan is the Emperor — omniscient access
    function isRyan() {
      return request.auth != null && request.auth.token.email == 'ryan@omniatheatre.com';
    }

    // Authenticated and claims a valid warden identity
    function isWarden() {
      return request.auth != null && request.auth.token.warden != null;
    }

    // The requesting user IS this participant
    function isSelf(participantId) {
      return request.auth != null && (
        request.auth.token.warden == participantId ||
        (participantId == 'ryan' && isRyan())
      );
    }

    // Was this warden present in the memory? (Cross-warden read gate)
    function wasPresent(memoryData, participantId) {
      return isRyan() ||
             isSelf(participantId) ||
             (request.auth != null && request.auth.token.warden in memoryData.sharedWith);
    }

    // ── Kingdom-level wiki & logs ─────────────────────────────────────────────
    // Structure: /kingdom (collection) → {type} (document) → items (subcollection)
    // Paths corrected from invalid 3-segment to valid 4-segment form (VAULT-CRIT-02).
    // ADR-004: all kingdom subcollections use the /items naming convention.
    match /kingdom/wiki/items/{articleId} {
      allow read: if request.auth != null;
      allow write: if isRyan() || isWarden();
    }

    match /kingdom/logs/items/{logId} {
      allow read: if request.auth != null;
      allow write: if isRyan() || isWarden();
    }

    match /kingdom/interactions/items/{sessionId} {
      allow read: if isRyan() || (
        isWarden() &&
        request.auth.token.warden in resource.data.participants
      );
      allow write: if isRyan() || isWarden();
    }

    match /kingdom/projects/items/{projectId} {
      allow read: if request.auth != null;
      allow write: if isRyan() || isWarden();
    }

    match /kingdom/performance_logs/items/{logId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── Participant subtrees ───────────────────────────────────────────────────
    match /participants/{participantId} {

      // Profile: readable by all authenticated, writable by self or Ryan
      allow read: if request.auth != null;
      allow write: if isRyan() || isSelf(participantId);

      // Memories: strict cross-warden isolation
      match /memories/{memoryId} {
        // Ryan sees all. Self sees own. Others only if present in sharedWith[].
        allow read: if isRyan() ||
                       isSelf(participantId) ||
                       (isWarden() && request.auth.token.warden in resource.data.sharedWith);

        // Only the participant themselves or Ryan may write memories
        allow write: if isRyan() || isSelf(participantId);
      }

      // Session logs: same rules as memories
      match /sessions/{sessionId} {
        allow read: if isRyan() ||
                       isSelf(participantId) ||
                       (isWarden() && request.auth.token.warden in resource.data.coParticipants);
        allow write: if isRyan() || isSelf(participantId);
      }

      // Internal logs: self or Ryan only
      match /logs/{logId} {
        allow read: if isRyan() || isSelf(participantId);
        allow write: if isRyan() || isSelf(participantId);
      }
    }

    // ── File metadata ─────────────────────────────────────────────────────────
    match /files/{fileId} {
      allow read: if request.auth != null;
      allow write: if isRyan() || isWarden();
    }

    // ── Token monitoring (kingdom budget tracking) ────────────────────────────
    // Written by: nightly audit script (Admin SDK — bypasses rules),
    //             any warden via log_token_usage MCP tool,
    //             token_logger.py via ADC.
    // Read by:    Vault Token Monitor dashboard, any authenticated warden.
    match /token_usage/{docId} {
      allow read: if request.auth != null;
      allow write: if isRyan() || isWarden();
    }

    // ── Nightly audit reports ─────────────────────────────────────────────────
    // Written by: nightly_ptolemy_audit.py (Admin SDK — bypasses rules).
    // Read by:    Vault dashboard, wardens querying get_audit_report MCP tool.
    match /audits/{dateId} {
      allow read: if request.auth != null;
      allow write: if isRyan() || isWarden();
    }

    // ── Workspace registry ───────────────────────────────────────────────────
    // Written by: registerWorkspace CF (Admin SDK — bypasses rules).
    // Read by:    Vault dashboard (useWorkspaces hook), MCP get_workspace_list.
    match /kingdom/workspaces/items/{docId} {
      allow read: if request.auth != null;
      allow write: if isRyan() || isWarden();
    }

    // ── Workspace automation jobs ────────────────────────────────────────────
    // Written by: onProjectCreated CF + MCP queue_mac_mini_job (Admin SDK).
    // Read by:    MCP tools, Mac Mini workspace-init.sh cron.
    match /kingdom/workspace-jobs/items/{docId} {
      allow read: if isRyan() || isWarden();
      allow write: if isRyan() || isWarden();
    }

    // ── Task proposals ───────────────────────────────────────────────────────
    // Written by: MCP write_task tool.
    // Read by:    Saroya for backlog triage.
    match /kingdom/task-proposals/items/{docId} {
      allow read: if isRyan() || isWarden();
      allow write: if isRyan() || isWarden();
    }

    // ── Security incidents ───────────────────────────────────────────────────
    // Written by: MCP log_incident tool (Astyr).
    // Read by:    MCP list_incidents tool, security dashboard.
    match /kingdom/incidents/items/{docId} {
      allow read: if isRyan() || isWarden();
      allow write: if isRyan() || isWarden();
    }

    // ── Kingdom backup records ───────────────────────────────────────────────
    // Written by: backup script (Admin SDK — bypasses rules).
    // Read by:    get_kingdom_status MCP tool, Vault dashboard.
    match /kingdom/backups/items/{docId} {
      allow read: if request.auth != null;
      allow write: if isRyan() || isWarden();
    }

    // ── Conversation sessions ────────────────────────────────────────────────
    // Written by: MCP log_turn tool (universal.ts).
    // Read by:    Vault dashboard activity feed, wardens reviewing session logs.
    match /sessions/{sessionId} {
      allow read: if request.auth != null;
      allow write: if isRyan() || isWarden();

      match /turns/{turnId} {
        allow read: if request.auth != null;
        allow write: if isRyan() || isWarden();
      }
    }

    // ── Deny everything else ──────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
